# Copy to .env and fill in. The pipeline reads these via @nestjs/config.
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key

# Optional overrides (defaults shown)
PORT=3000
OUTPUT_DIR=outputs
# Where uploaded screen recordings are stored (for the demo-embed feature).
UPLOAD_DIR=uploads
# Model / voice tuning
SCRIPT_MODEL=claude-haiku-4-5
TTS_MODEL=tts-1
TTS_VOICE=nova
# Video output
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
# Cost accounting (USD per 1,000,000 units). Defaults match the models above:
# claude-haiku-4-5 ($1 in / $5 out per Mtok) and tts-1 ($15 per Mchar).
# Update these if you change models or provider pricing changes.
ANTHROPIC_INPUT_COST_PER_MTOK=1
ANTHROPIC_OUTPUT_COST_PER_MTOK=5
TTS_COST_PER_MCHAR=15
